# Variables:

  # Establece la Tecla Super
  set $mod Mod4

  # Establece la Variable Exit
  set $exit swaymsg exit

  # Establece la Terminal Preferida
  set $term foot
  
  # Establece el Menu de Aplicaciones
  set $menu rofi -show drun

  # Establece la Variable del Menu de Opciones de Apagado
  set $powermenu rofi -show power-menu -modi power-menu:rofi-power-menu

  # Establece el Explorador de Archivos Preferido
  set $file nemo

  # Establece el Menu de Alicaciones
  set $browser vivaldi

# Autoarranque:

  # Waybar
  exec waybar &

  # Agente Polkit de Mate
  exec /usr/libexec/polkit-mate-authentication-agent-1

# Configuracion de la Salida:

  # Establece el Wallpaper
  output * bg /home/antsoftware21/Pictures/Wallpapers/Niko-OneShot.png fill

  # Le da al Segundo Monitor la Posicion y la Resolucion 

    # Pantalla Externa (Asus Vivobook)
    output HDMI-A-1 position 1920,0 resolution 1920x1080

    # Pantalla Interna (Asus Vivobook)
    output eDP-1 position 0,490 resolution 1920x1080

    # Pantalla Externa (Dell Latitude)
    # output HDMI-A-1 position 1366,0 resolution 1920x1080

    # Pantalla Interna (Dell Latitude)
    # output eDP-1 position 0,620 resolution 1366x768    

  # Puedes obtener los nombres de tus Salidas con el comando swaymsg -t get_outputs

# Configuracion de Bloqueo en Suspension:
  exec swayidle -w \
       timeout 300 'swaylock --screenshots --clock --indicator --indicator-radius 100 --indicator-thickness 7 --effect-blur 7x5 --effect-vignette 0.5:0.5 --grace 2 --fade-in 0.2' \
       timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
       before-sleep 'swaylock --screenshots --clock --indicator --indicator-radius 100 --indicator-thickness 7 --effect-blur 7x5 --effect-vignette 0.5:0.5 --grace 2 --fade-in 0.2'

# Configuracion de la Entrada:

  # Panel Tactil  
  input type:touchpad {
      dwt disable
      tap enabled
      natural_scroll enabled
      middle_emulation enabled
  }

  # Teclado
  input type:keyboard {
     xkb_layout "es"
  }

# Atajos de Teclado:

  # Atajos Basicos:
 
    # Cerrar Ventanas
    bindsym $mod+w kill

    # Recarga el Archivo de Configuracion
    bindsym $mod+Shift+r reload
    
    # Salir de Sway
    bindsym $mod+Shift+q exec $exit

    # Permite que pueda modificar las Ventanas Flotantes con el Raton
    floating_modifier $mod normal

    # Inicia una Terminal
    bindsym $mod+Return exec $term

    # Inicia el Menu de Aplicaciones
    bindsym $mod+m exec $menu

    # Inicia el Explorador de Archivos
    bindsym $mod+a exec $file

    # Inicia el Navegador Web
    bindsym $mod+n exec $browser

  # Atajos para Moverse:

    # Mueve el Foco en Diferentes Direcciones
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    # Mueve la Ventana a Diferentes Direcciones
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+Right move right

  # Espacios de Trabajo:

    # Cambia de Espacio de Trabajo
    bindsym $mod+1 workspace number 1
    bindsym $mod+2 workspace number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4
    bindsym $mod+5 workspace number 5

    # Mueve la Ventana a Otros Espacios de Trabajo
    bindsym $mod+Shift+1 move container to workspace number 1
    bindsym $mod+Shift+2 move container to workspace number 2
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace number 4
    bindsym $mod+Shift+5 move container to workspace number 5

    # Los Espacios de Trabajo pueden tener Diferentes Nombres, no solo Numeros.

  # Distintos Layouts:

    # Ventana en Modo Mosaico Horizontal 
    bindsym $mod+b splith 

    # Ventana en Modo Mosaico Vertical
    bindsym $mod+v splitv

    # Hace que la Aplicacion con el Foco se ponga en Pantalla Completa
    bindsym $mod+f fullscreen

    # Cambia entre Ventanas en Mosaico o Flotante
    bindsym $mod+Shift+space floating toggle

    # Cambia el Foco entre Ventanas en Mosaico o Flotantes
    bindsym $mod+space focus mode_toggle

  # Modo de Redimensionado:

  mode "resize" {

    # Redmiensionado en Varias Direcciones
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    # Volver al Modo Default
    bindsym Return mode "default"
    bindsym Escape mode "default"

  }
    
    # Atajo Para el Redimensionado
    bindsym $mod+r mode "resize"


  # Teclas de Utilidad:

    # Teclas Especiales para Ajustar el Sonido
    bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
    bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
    bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
    bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle

    # Teclas Especiales para Ajustar el Brillo
    bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
    bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+

    # Tecala para tomar una Captura de Pantalla
    bindsym Print exec mkdir -p ~/Pictures/Screenshots && grim ~/Pictures/Screenshots/$(date +%Y-%m-%d_%H-%m-%s).png

    # Inicia el Menu de Opciones de Apagado
    bindsym XF86PowerOff exec $powermenu

    # Inicia el Control del Volumen
    bindsym $mod+o exec foot pulsemixer

    # Inicia el Gestor Bluetooth
    bindsym $mod+i exec foot bluetuith

    # Inicia el Gestor WiFi
    bindsym $mod+u exec foot nmtui

    # Inicia el Selector de Perfiles de Potencia
    bindsym $mod+p exec --no-startup-id ~/.config/rofi/script/power-profiles.sh

# Configuracion del Aspecto:

  # Configuracion de las Gaps
  gaps outer 6
  gaps inner 6

  # Configuracion de los Bordes Redondeados
  corner_radius 8

  # Tamaño de los Bordes
  default_border pixel 3
  default_floating_border pixel 3

  # Configuracion del el Efecto Blur
  blur enable
  blur_xray disable
  blur_passes 3
  blur_radius 5
  
  # Activa la Transparencia de las Ventanas
  for_window [class=".*"] opacity 0.59
  for_window [app_id=".*"] opacity 0.70

}

include /etc/sway/config.d/*
